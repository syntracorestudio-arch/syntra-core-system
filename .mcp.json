{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp", "--cwd", "projects/syntra-core-website"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--isolated"]
    },
    "pollinations": {
      "command": "npx",
      "args": ["-y", "@pinkpixel/mcpollinations"]
    }
  }
}
