# StudioFlow — variables de entorno (EJEMPLO, sin secretos)
# Copiar a `.env.local` (gitignored) y completar con los valores del proyecto Supabase.
# NUNCA commitear `.env.local` ni pegar secretos en el repo.

# Project ref de Supabase (no secreto; está en la URL del dashboard)
SUPABASE_PROJECT_REF=tu-project-ref

# Públicas (van al browser; protegidas por RLS)
NEXT_PUBLIC_SUPABASE_URL=https://tu-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# SECRETO · server-only · SIN prefijo NEXT_PUBLIC · bypassa RLS
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Clave de cifrado (32 bytes base64) para secretos de terceros (ej. token MercadoPago del estudio)
MP_ENC_KEY=
