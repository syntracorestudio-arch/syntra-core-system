# StockFlow — variables de entorno
# Copiar a .env.local y completar. NUNCA commitear .env.local.

# --- Supabase (proyecto PROPIO de StockFlow, separado del de StudioFlow) ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: BYPASSA RLS. Sin prefijo NEXT_PUBLIC, jamás al browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push (tanda 1F) ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:syntracore.studio@gmail.com

# --- Cron de alertas (tanda 1F) ---
# Secreto que valida el header de /api/cron/alerts
CRON_SECRET=
