# ============================================================
# SYNTRA CORE — Variables de entorno
# Copiá este archivo como `.env.local` y completá los valores.
# .env.local NUNCA se commitea (ver .gitignore).
# ============================================================

# --- Supabase (captación de leads) ---
# Dashboard → Project Settings → API
SUPABASE_URL="https://TU-PROYECTO.supabase.co"

# SERVICE ROLE KEY — secreta, SOLO servidor. Nunca exponer al cliente.
# (Project Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# --- Notificación de leads vía n8n (Sprint 4A) ---
# URL del webhook de producción de n8n. Si se deja vacío, no se notifica
# (el lead igual se persiste en Supabase). Recibe POST con:
#   headers:
#     x-idempotency-key: <lead.id>            (dedup en n8n)
#     x-syntra-signature: <LEAD_WEBHOOK_SECRET>  (LEGACY, en claro — en migración)
#     x-syntra-timestamp: <epoch_seconds>     (TASK-023A)
#     x-syntra-hmac: v1=<hmac_hex>            (TASK-023A — firma real, ver abajo)
#   body:    { event:"lead.created", occurred_at, lead:{...}, links:{ panel } }
# LEAD_WEBHOOK_URL="https://tu-n8n.com/webhook/xxxxxxxx"
#
# Secreto compartido app↔n8n. Se reusa como CLAVE HMAC del nuevo esquema de firma:
#   message = `${x-syntra-timestamp}.${rawBody}`
#   x-syntra-hmac = "v1=" + HMAC_SHA256(LEAD_WEBHOOK_SECRET, message)  (hex)
# Migración en curso (TASK-023): durante esta fase la app envía AMBOS — el legacy
# x-syntra-signature (secreto en claro) y el nuevo x-syntra-hmac — para no romper
# el n8n actual. n8n debe migrar a validar el HMAC sobre el RAW body (ventana 300s,
# comparación timing-safe) y luego se quita el legacy. El secreto NO viaja en la firma.
# Generar: openssl rand -hex 32
# LEAD_WEBHOOK_SECRET="genera-un-secreto-largo-aleatorio"

# --- Analytics (Plausible) ---
# Dominio registrado en Plausible. Si se deja vacío, Plausible NO se monta
# (track() cae a no-op seguro; en dev igual loguea por consola).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="syntracore.dev"
# (Opcional, solo self-host) override del script:
# NEXT_PUBLIC_PLAUSIBLE_SRC="https://tu-plausible/js/script.js"

# --- Panel interno de leads (Sprint 3) ---
# Passcode de acceso al panel (/panel/login). Elegí uno fuerte.
PANEL_PASSWORD="cambiame-por-un-passcode-fuerte"
# Secreto para firmar la cookie de sesión (HMAC). Largo y aleatorio.
# Generar: openssl rand -hex 32
PANEL_SESSION_SECRET="genera-un-secreto-largo-aleatorio-de-64-chars"
